#:kivy 1.0.9
#:import Window kivy.core.window.Window

<Health>:
    size: Window.width * 0.04, Window.width * 0.04
    canvas:
        Rectangle:
            source:'./assets/heart.png'
            pos:self.pos
            size:self.size

<AttackPower>:
    size: Window.width * 0.1, Window.width * 0.1
    canvas:
        Rectangle:
            pos: self.pos
            size: self.size
            source : root.image_source

<ExplosionPower>:
    size: Window.width * 0.12, Window.width * 0.12
    canvas:
        Rectangle:
            pos:self.pos
            size: self.size
            source:root.image_source
<ExplosionPlayer>:
    size: Window.width * 0.12, Window.width * 0.12
    canvas:
        Rectangle:
            pos: self.pos
            size: self.size
            source: root.image_source
<ExplosionPlayerNotHurt>:
    size: Window.width * 0.12, Window.width * 0.12
    canvas:
        Rectangle:
            pos:self.pos
            size: self.size
            source:root.image_source
            
<Player>:
    size_hint:None, None
    size : Window.width * 0.15, Window.width * 0.15
    canvas:
        Rectangle:
            pos: (self.x - self.width * 0.125, self.y) if 'Charge' in root.image_source else self.pos
            size: (self.width * 1.25, self.height * 1.25) if 'Charge' in root.image_source else self.size
            source: root.image_source
<Enemy>:
    size_hint:None, None
    size : Window.width * 0.15, Window.width * 0.15
    canvas:
        Rectangle:
            pos: (self.x - self.width * 0.125, self.y) if 'Charge' in root.image_source else self.pos
            size: (self.width * 1.25, self.height * 1.25) if 'Charge' in root.image_source else self.size
            source: root.image_source

<HomePage>:
    canvas.before:
        Rectangle:
            source: './assets/backgroundhome.png'
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.22, 0.8, 1, 0.2
        Rectangle:
            pos: self.pos
            size: self.size

<WinScreen>:
    canvas.before:
        Color:
            rgba: 0.22, 0.8, 1, 0.2
        Rectangle:
            source:'./assets/backgroundwinlose.png'
            pos: self.pos
            size: self.size

<LoseScreen>:
    canvas.before:
        Color:
            rgba: 0.22, 0.8, 1, 0.2
        Rectangle:
            source:'./assets/backgroundwinlose.png'
            pos: self.pos
            size: self.size

<GameWidget>:
    player : player_left
    enemy : enemy_right 
    
    canvas:
        Rectangle:
            source: './assets/background2.png'
            pos: self.pos
            size: self.size

        Rectangle:
            source:'./assets/energy.png'
            pos: self.width * 0.22 - self.width * 0.03, self.top * 0.5
            size: self.width * 0.06, self.width * 0.06
        Rectangle:
            source:'./assets/energy.png'
            pos: self.width * 0.78 - self.width * 0.03, self.top * 0.5
            size: self.width * 0.06, self.width * 0.06


         #เอาไว้ใส่เป็นรูปบอกท่ากับพลังงานที่ใช้
        Rectangle:
            source: './assets/prepare.png'
            pos: self.width / 2 - (self.width / 12) * 5.5, self.top / 22
            size: self.width / 12, self.width / 12 
        Rectangle:
            source: './assets/1.png'
            pos: self.width / 2 - (self.width / 12) * 4.5, self.top / 22
            size: self.width / 12, self.width / 12 
        Rectangle:
            source: './assets/2.png'
            pos: self.width / 2 - (self.width / 12) * 3.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/3.png'
            pos: self.width / 2 - (self.width / 12) * 2.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/4.png'
            pos: self.width / 2 - (self.width / 12) * 1.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/5.png'
            pos: self.width / 2 - (self.width / 12) * 0.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/6.png'
            pos: self.width / 2 + (self.width / 12) * 0.5, self.top / 22
            size: self.width / 12, self.width / 12
        
        # กล่องสีขาวเอาไว้บังคำว่า 0 point
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.width / 2 + (self.width / 12) * 0.5 + (self.width / 12) * 0.25, self.top / 22 + (self.width / 12) * 0.02
            size: (self.width / 12) * 0.5, (self.width / 12) * 0.18
        Color:
            rgba: 1, 1, 1, 1
            
        Rectangle:
            source: './assets/7.png'
            pos: self.width / 2 + (self.width / 12) * 1.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/8.png'
            pos: self.width / 2 + (self.width / 12) * 2.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/9.png'
            pos: self.width / 2 + (self.width / 12) * 3.5, self.top / 22
            size: self.width / 12, self.width / 12
        Rectangle:
            source: './assets/10.png'
            pos: self.width / 2 + (self.width / 12) * 4.5, self.top / 22
            size: self.width / 12, self.width / 12
            
    # Label ทับกล่องขาวเพื่อแก้ค่า Point ของท่า K
    Label:
        text: "-1 point"
        color: 0, 0, 0, 1
        font_size: root.width * 0.012
        bold: True
        center_x: root.width / 2 + (root.width / 12) * 1.0
        center_y: root.top / 22 + (root.width / 12) * 0.1
        
    Label:
        color: 0, 0, 1, 1
        text: root.stage  
        font_size: root.width * 0.03
        center: self.parent.center 
         
    #กรณีที่มีการอ้างอิงถึงอ็อบเจ็กต์ด้านนอกคลาสปัจจุบัน เช่น <Player> หรือ <Enemy> จะใช้ root เพื่ออ้างอิงถึง GameWidget แทน self 
    Player:
        id: player_left
        pos: root.width * 0.22 - root.width * 0.075, root.top / 4

    Enemy:
        id: enemy_right
        pos: root.width * 0.78 - root.width * 0.075, root.top / 4
    
    Label:
        color: 0.6, 0.4, 0.8, 1  
        font_size: root.width * 0.04
        center_x: root.width * 0.22
        center_y: root.top * 0.5 + root.width * 0.03
        text: str(root.player.energy)
   
    Label:
        color: 0.6, 0.4, 0.8, 1  
        font_size: root.width * 0.04
        center_x: root.width * 0.78
        center_y: root.top * 0.5 + root.width * 0.03
        text: str(root.enemy.energy)
